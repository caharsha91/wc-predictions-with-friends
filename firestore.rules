rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasEmail() {
      return isSignedIn() && request.auth.token.email is string;
    }

    function normalizedEmail() {
      return hasEmail() ? request.auth.token.email.lower() : '__missing__';
    }

    function isAllowlisted(leagueId) {
      return hasEmail()
        && exists(
          /databases/$(database)/documents/leagues/$(leagueId)/members/$(normalizedEmail())
        );
    }

    function isAdmin(leagueId) {
      return hasEmail()
        && exists(
          /databases/$(database)/documents/leagues/$(leagueId)/members/$(normalizedEmail())
        )
        && get(
          /databases/$(database)/documents/leagues/$(leagueId)/members/$(normalizedEmail())
        ).data.isAdmin == true;
    }

    function selfMemberId(leagueId) {
      return hasEmail()
        && exists(
          /databases/$(database)/documents/leagues/$(leagueId)/members/$(normalizedEmail())
        )
        ? get(
          /databases/$(database)/documents/leagues/$(leagueId)/members/$(normalizedEmail())
        ).data.id
        : '__missing__';
    }

    function isSelfMember(leagueId, userId) {
      return hasEmail() && selfMemberId(leagueId) is string && selfMemberId(leagueId) == userId;
    }

    function isSelfEmail(email) {
      return hasEmail() && normalizedEmail() == email;
    }

    function isValidMemberSelfMutableUpdate(email) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'theme',
          'lastRoute',
          'rivalUserIds',
          'updatedAt',
          'authUid',
          'email',
          'displayName',
          'photoURL'
        ])
        && (!('lastRoute' in request.resource.data)
          || request.resource.data.lastRoute == null
          || request.resource.data.lastRoute is string)
        && (!('rivalUserIds' in request.resource.data)
          || (
            request.resource.data.rivalUserIds is list
            && request.resource.data.rivalUserIds.size() <= 3
          ))
        && (!('authUid' in request.resource.data) || request.resource.data.authUid is string)
        && (!('email' in request.resource.data)
          || (
            request.resource.data.email is string
            && (
              request.resource.data.email == email
              || request.resource.data.email.lower() == email.lower()
            )
          ))
        && (!('displayName' in request.resource.data) || request.resource.data.displayName is string)
        && (!('photoURL' in request.resource.data)
          || request.resource.data.photoURL == null
          || request.resource.data.photoURL is string);
    }

    function groupStageLockDeadlineUtc() {
      // First group kickoff is 2026-06-11T19:00:00Z; lock opens 30 minutes earlier.
      // TODO(vLater): move this deadline to shared tournament config once rules can read that source.
      return timestamp.date(2026, 6, 11) + duration.value(18, 'h') + duration.value(30, 'm');
    }

    function isBeforeGroupStageLock() {
      return request.time < groupStageLockDeadlineUtc();
    }

    match /leagues/{leagueId} {
      allow read, write: if false;

      match /members/{email} {
        allow get, list: if isAllowlisted(leagueId);
        allow create, update: if isAdmin(leagueId)
          || (isAllowlisted(leagueId) && isSelfEmail(email) && isValidMemberSelfMutableUpdate(email));
        allow delete: if isAdmin(leagueId);
      }

      match /picks/{userId} {
        allow get: if (isAllowlisted(leagueId) && isSelfMember(leagueId, userId)) || isAdmin(leagueId);
        allow list: if isAdmin(leagueId);
        allow create, update: if isAllowlisted(leagueId)
          && isSelfMember(leagueId, userId)
          && request.resource.data.userId == userId;
      }

      match /bracket-group/{userId} {
        allow get: if (isAllowlisted(leagueId) && isSelfMember(leagueId, userId)) || isAdmin(leagueId);
        allow list: if isAdmin(leagueId);
        allow create, update: if isAllowlisted(leagueId)
          && isSelfMember(leagueId, userId)
          && request.resource.data.userId == userId
          && isBeforeGroupStageLock();
      }

      match /bracket-knockout/{userId} {
        allow get: if (isAllowlisted(leagueId) && isSelfMember(leagueId, userId)) || isAdmin(leagueId);
        allow list: if isAdmin(leagueId);
        allow create, update: if isAllowlisted(leagueId)
          && isSelfMember(leagueId, userId)
          && request.resource.data.userId == userId;
      }
    }

  }
}
